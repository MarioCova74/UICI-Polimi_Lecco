<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="UICI - Lettore audio accessibile per contenuti aperti tramite QR code" />
  <title>UICI | Audio Guide</title>
  <style>
    :root {
      --bg: #f4f7fb;
      --panel: #ffffff;
      --panel-soft: #f8fbff;
      --text: #17212f;
      --muted: #5f6b7a;
      --accent: #0a5bd8;
      --accent-2: #083f96;
      --border: #d8e1ee;
      --shadow: 0 16px 40px rgba(18, 55, 105, 0.10);
      --radius-xl: 24px;
      --radius-lg: 18px;
      --radius-md: 14px;
      --focus: 0 0 0 4px rgba(10, 91, 216, 0.18);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(10, 91, 216, 0.10), transparent 32%),
        linear-gradient(180deg, #eef4ff 0%, var(--bg) 100%);
      color: var(--text);
      min-height: 100vh;
    }

    .page {
      width: 100%;
      max-width: 920px;
      margin: 0 auto;
      padding: 24px;
    }

    .hero {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .hero-top {
      padding: 20px 24px;
      border-bottom: 1px solid var(--border);
      display: flex;
      gap: 16px;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      background: linear-gradient(90deg, #ffffff 0%, #f7fbff 100%);
    }

    .brand {
      display: flex;
      gap: 14px;
      align-items: center;
    }

    .brand-mark {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent-2) 100%);
      color: #fff;
      display: grid;
      place-items: center;
      font-weight: 800;
      font-size: 1.05rem;
      letter-spacing: 0.03em;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.2);
    }

    .brand-text small {
      display: block;
      color: var(--accent);
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .brand-text h1 {
      font-size: clamp(1.6rem, 3.8vw, 2.8rem);
      line-height: 1.1;
      margin: 0;
    }

    .language-switcher {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .language-switcher label {
      font-weight: 700;
      color: var(--muted);
    }

    select, button, a { font: inherit; }

    select {
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--text);
      min-width: 160px;
    }

    select:focus, button:focus, a:focus {
      outline: none;
      box-shadow: var(--focus);
    }

    .hero-body {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 24px;
      padding: 28px;
    }

    .content-panel, .info-panel {
      background: var(--panel-soft);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 22px;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 12px;
      font-weight: 800;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 0.9rem;
    }

    .artwork-title {
      margin: 0 0 10px;
      font-size: clamp(1.5rem, 3.6vw, 2.3rem);
      line-height: 1.15;
      word-break: break-word;
    }

    .artwork-meta {
      margin: 0 0 16px;
      color: var(--muted);
      font-size: 1.02rem;
      line-height: 1.55;
    }

    .status {
      margin: 0 0 18px;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.6;
    }

    .audio-shell {
      padding: 18px;
      border-radius: var(--radius-md);
      border: 2px solid var(--border);
      background: #fff;
    }

    audio {
      width: 100%;
      margin: 12px 0 0;
      min-height: 56px;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 16px;
    }

    .btn {
      border: 0;
      border-radius: 12px;
      padding: 14px 18px;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
    }

    .btn-primary:hover { background: var(--accent-2); }

    .btn-secondary {
      background: #fff;
      color: var(--text);
      border: 1px solid var(--border);
    }

    .btn-secondary:hover { background: #f3f7fd; }

    .info-panel h2 {
      margin: 0 0 10px;
      font-size: 1.2rem;
    }

    .info-panel p, .info-panel li, .content-panel p {
      font-size: 1rem;
      line-height: 1.7;
    }

    .info-panel ul {
      margin: 10px 0 0;
      padding-left: 20px;
    }

    .badge {
      display: inline-block;
      padding: 8px 10px;
      background: #eaf2ff;
      color: var(--accent-2);
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.92rem;
      margin-bottom: 14px;
    }

    .footer-note {
      margin-top: 18px;
      font-size: 0.96rem;
      color: var(--muted);
    }

    .help {
      margin-top: 24px;
      background: #fffef6;
      border: 1px solid #ecd98c;
      border-radius: var(--radius-lg);
      padding: 18px 20px;
      line-height: 1.7;
    }

    code {
      background: #edf3ff;
      border-radius: 8px;
      padding: 2px 6px;
      font-size: 0.95em;
      word-break: break-word;
    }

    .hidden { display: none !important; }

    @media (max-width: 780px) {
      .hero-body {
        grid-template-columns: 1fr;
        padding: 20px;
      }

      .hero-top { padding: 18px; }
      .page { padding: 14px; }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero" aria-labelledby="mainTitle">
      <div class="hero-top">
        <div class="brand" aria-label="UICI audio guide brand area">
          <div class="brand-mark" aria-hidden="true">UICI</div>
          <div class="brand-text">
            <small id="brandLabel">Accessible Audio</small>
            <h1 id="mainTitle">Guida audio accessibile</h1>
          </div>
        </div>

        <div class="language-switcher">
          <label for="languageSelect" id="languageLabel">Lingua</label>
          <select id="languageSelect" aria-label="Seleziona lingua">
            <option value="it">Italiano</option>
            <option value="en">English</option>
          </select>
        </div>
      </div>

      <div class="hero-body">
        <section class="content-panel" aria-live="polite">
          <div class="eyebrow" id="sectionLabel">Audio guide</div>
          <h2 class="artwork-title" id="audioTitle">Opera non specificata</h2>
          <p class="artwork-meta" id="artworkMeta">Scansiona il QR code per aprire automaticamente il contenuto audio corretto.</p>
          <p class="status" id="statusText">In attesa di un file audio valido.</p>

          <div class="audio-shell">
            <audio id="audioPlayer" controls preload="metadata">
              Il tuo browser non supporta la riproduzione audio.
            </audio>

            <div class="actions">
              <button class="btn btn-primary" id="playButton" type="button">Riproduci audio</button>
              <a class="btn btn-secondary hidden" id="downloadButton" href="#" download>Scarica audio</a>
            </div>
          </div>

          <p class="footer-note" id="footerNote">
            Questa pagina è progettata per essere semplice, leggibile e facile da usare anche su smartphone.
          </p>
        </section>

        <aside class="info-panel" aria-labelledby="infoTitle">
          <div class="badge" id="badgeText">QR Ready</div>
          <h2 id="infoTitle">Come funziona</h2>
          <p id="infoText">
            Ogni QR code può aprire direttamente un file audio relativo a un'opera, a un artista o a una descrizione accessibile.
          </p>
          <ul id="infoList">
            <li>Apri un file locale dal repository GitHub Pages.</li>
            <li>Usa un titolo personalizzato per l'opera.</li>
            <li>Condividi pagine semplici e accessibili per mostre ed eventi.</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="help" aria-labelledby="helpTitle">
      <strong id="helpTitle">Formato dei link QR</strong><br />
      <span id="helpIntro">Crea i QR code utilizzando uno dei seguenti formati:</span><br /><br />
      <code>?audio=audio/monalisa.mp3&amp;title=Monna%20Lisa</code><br />
      <code>?audio=audio/van-gogh.mp3&amp;title=Van%20Gogh&amp;lang=it</code><br />
      <code>?url=https%3A%2F%2Fexample.com%2Faudio.mp3&amp;title=Introduction&amp;lang=en</code>
    </section>
  </main>

  <script>
    const params = new URLSearchParams(window.location.search);
    const audioParam = params.get('audio');
    const urlParam = params.get('url');
    const titleParam = params.get('title');
    const langParam = params.get('lang');
    const artistParam = params.get('artist');
    const descParam = params.get('desc');

    const audioPlayer = document.getElementById('audioPlayer');
    const playButton = document.getElementById('playButton');
    const downloadButton = document.getElementById('downloadButton');
    const audioTitle = document.getElementById('audioTitle');
    const statusText = document.getElementById('statusText');
    const artworkMeta = document.getElementById('artworkMeta');
    const footerNote = document.getElementById('footerNote');
    const languageSelect = document.getElementById('languageSelect');

    const dictionary = {
      it: {
        htmlLang: 'it',
        brandLabel: 'Accessible Audio',
        mainTitle: 'Guida audio accessibile',
        languageLabel: 'Lingua',
        sectionLabel: 'Audio guide',
        defaultTitle: 'Opera non specificata',
        defaultMeta: 'Scansiona il QR code per aprire automaticamente il contenuto audio corretto.',
        waiting: 'In attesa di un file audio valido.',
        loaded: 'File audio caricato. Premi il pulsante per ascoltare.',
        invalid: 'Nessun file audio valido è stato fornito nel link del QR code.',
        play: 'Riproduci audio',
        download: 'Scarica audio',
        footer: 'Questa pagina è progettata per essere semplice, leggibile e facile da usare anche su smartphone.',
        badge: 'QR Ready',
        infoTitle: 'Come funziona',
        infoText: 'Ogni QR code può aprire direttamente un file audio relativo a un\'opera, a un artista o a una descrizione accessibile.',
        infoList: [
          'Apri un file locale dal repository GitHub Pages.',
          'Usa un titolo personalizzato per l\'opera.',
          'Condividi pagine semplici e accessibili per mostre ed eventi.'
        ],
        helpTitle: 'Formato dei link QR',
        helpIntro: 'Crea i QR code utilizzando uno dei seguenti formati:'
      },
      en: {
        htmlLang: 'en',
        brandLabel: 'Accessible Audio',
        mainTitle: 'Accessible audio guide',
        languageLabel: 'Language',
        sectionLabel: 'Audio guide',
        defaultTitle: 'Untitled artwork',
        defaultMeta: 'Scan the QR code to automatically open the correct audio content.',
        waiting: 'Waiting for a valid audio file.',
        loaded: 'Audio file loaded. Press the button to listen.',
        invalid: 'No valid audio file was provided in the QR code link.',
        play: 'Play audio',
        download: 'Download audio',
        footer: 'This page is designed to be simple, readable, and easy to use on smartphones.',
        badge: 'QR Ready',
        infoTitle: 'How it works',
        infoText: 'Each QR code can directly open an audio file linked to an artwork, an artist, or an accessible description.',
        infoList: [
          'Open a local file from the GitHub Pages repository.',
          'Use a custom title for the artwork.',
          'Share simple and accessible pages for exhibitions and events.'
        ],
        helpTitle: 'QR link format',
        helpIntro: 'Create QR codes using one of the following formats:'
      }
    };

    function safeDecode(value) {
      if (!value) return '';
      try { return decodeURIComponent(value); }
      catch { return value; }
    }

    function isSafeRelativePath(path) {
      return /^[a-zA-Z0-9_\\-./]+\\.(mp3|wav|ogg|m4a)$/i.test(path);
    }

    function getFileName(path) {
      const lastPart = path.split('/').pop() || path;
      return safeDecode(lastPart);
    }

    function applyLanguage(lang) {
      const t = dictionary[lang] || dictionary.it;
      document.documentElement.lang = t.htmlLang;
      document.getElementById('brandLabel').textContent = t.brandLabel;
      document.getElementById('mainTitle').textContent = t.mainTitle;
      document.getElementById('languageLabel').textContent = t.languageLabel;
      document.getElementById('sectionLabel').textContent = t.sectionLabel;
      document.getElementById('badgeText').textContent = t.badge;
      document.getElementById('infoTitle').textContent = t.infoTitle;
      document.getElementById('infoText').textContent = t.infoText;
      document.getElementById('helpTitle').textContent = t.helpTitle;
      document.getElementById('helpIntro').textContent = t.helpIntro;
      playButton.textContent = t.play;
      downloadButton.textContent = t.download;
      footerNote.textContent = t.footer;

      const infoList = document.getElementById('infoList');
      infoList.innerHTML = '';
      t.infoList.forEach(item => {
        const li = document.createElement('li');
        li.textContent = item;
        infoList.appendChild(li);
      });

      if (!audioPlayer.src) {
        audioTitle.textContent = t.defaultTitle;
        artworkMeta.textContent = t.defaultMeta;
        statusText.textContent = t.waiting;
      }
    }

    let currentLanguage = (langParam && dictionary[langParam]) ? langParam : 'it';
    languageSelect.value = currentLanguage;
    applyLanguage(currentLanguage);

    let audioSource = null;

    if (audioParam && isSafeRelativePath(audioParam)) {
      audioSource = audioParam;
    } else if (urlParam) {
      try {
        const parsed = new URL(urlParam);
        if (['http:', 'https:'].includes(parsed.protocol)) {
          audioSource = parsed.href;
        }
      } catch (error) {
        console.error('Invalid external URL', error);
      }
    }

    if (audioSource) {
      const t = dictionary[currentLanguage];
      const decodedTitle = safeDecode(titleParam) || getFileName(audioSource);
      const decodedArtist = safeDecode(artistParam);
      const decodedDesc = safeDecode(descParam);

      audioPlayer.src = audioSource;
      audioTitle.textContent = decodedTitle;
      artworkMeta.textContent = decodedDesc || (decodedArtist ? decodedArtist : t.defaultMeta);
      statusText.textContent = t.loaded;
      downloadButton.href = audioSource;
      downloadButton.classList.remove('hidden');
    } else {
      statusText.textContent = dictionary[currentLanguage].invalid;
    }

    playButton.addEventListener('click', async () => {
      try {
        await audioPlayer.play();
      } catch (error) {
        statusText.textContent = currentLanguage === 'it'
          ? 'Premi il controllo audio del browser per avviare la riproduzione.'
          : 'Press the browser audio control to start playback.';
      }
    });

    languageSelect.addEventListener('change', () => {
      currentLanguage = languageSelect.value;
      applyLanguage(currentLanguage);

      if (audioPlayer.src) {
        const t = dictionary[currentLanguage];
        statusText.textContent = t.loaded;
        playButton.textContent = t.play;
        downloadButton.textContent = t.download;
      }
    });
  </script>
</body>
</html>
